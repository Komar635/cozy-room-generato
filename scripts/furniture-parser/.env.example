# Cloud.ru Database Configuration
CLOUD_DB_HOST=your-cloud-ru-host
CLOUD_DB_PORT=5432
CLOUD_DB_NAME=furniture_db
CLOUD_DB_USER=your-username
CLOUD_DB_PASSWORD=your-password

# Parser Settings
PARSE_INTERVAL_HOURS=6
MAX_CONCURRENT_REQUESTS=5
REQUEST_DELAY_MS=2000

# Proxy Settings (optional)
USE_PROXY=false
PROXY_HOST=
PROXY_PORT=

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/parser.log