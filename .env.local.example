# База данных (локальная PostgreSQL)
DATABASE_URL=postgresql://app_user:your_secure_password@localhost:5432/reality_digitizer_3d

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here

# Для разработки - простая аутентификация
AUTH_PROVIDER=local

# MinIO (локальное S3-совместимое хранилище)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=reality-digitizer-3d

# Google Gemini API (бесплатный LLM)
GEMINI_API_KEY=your-gemini-api-key
