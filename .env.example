# Рекомендуемые API для дизайна интерьера (2024)

# Replicate API (ГЛАВНЫЙ ВЫБОР - работает стабильно)
# Получить: https://replicate.com/ → Account → API tokens
# Бесплатно: $10 кредитов (~500 изображений)
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# OpenAI API (для текстовых рекомендаций)
# Получить: https://platform.openai.com/api-keys
# Бесплатно: $5 кредитов (3 месяца)
OPENAI_API_KEY=sk-your_openai_key_here

# ⚠️ HuggingFace API больше НЕ РАБОТАЕТ (ошибка 410)
# Оставлено для совместимости, но не используется
# HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Database (for future use)
DATABASE_URL=your_database_url_here

# Next.js
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000