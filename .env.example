# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# RoomGPT API Integration - Российские цены и рубли
# ========================================================

# Replicate API (ГЛАВНЫЙ ВЫБОР - работает стабильно)
# Получить: https://replicate.com/ → Account → API tokens
# Бесплатно: $10 кредитов (~500 изображений)
# Используется для: генерация изображений интерьера, дизайн комнат
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# OpenAI API (для текстовых рекомендаций и анализа)
# Получить: https://platform.openai.com/api-keys
# Бесплатно: $5 кредитов (3 месяца)
# Используется для: умные рекомендации мебели, оптимизация бюджета
OPENAI_API_KEY=sk-your_openai_key_here

# ⚠️ HuggingFace API больше НЕ РАБОТАЕТ (ошибка 410)
# Оставлено для совместимости, но не используется
# HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Настройки адаптации под российский рынок
# ========================================
# Минимальный бюджет для рекомендаций (в рублях)
MIN_BUDGET_RUB=10000
# Минимальный бюджет для дизайна комнаты (в рублях)  
MIN_DESIGN_BUDGET_RUB=15000
# Валюта для отображения цен
CURRENCY=RUB
# Локаль для форматирования цен
LOCALE=ru-RU

# Parser Configuration (for background parsing)
PARSE_INTERVAL_HOURS=6
ENABLE_PARSER=false